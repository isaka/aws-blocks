{
  "name": "blocks",
  "version": "1.0.0",
  "type": "module",
  "workspaces": [
    "packages/hosting",
    "packages/pipeline",
    "packages/core",
    "packages/bb-kv-store",
    "packages/bb-distributed-table",
    "packages/auth-common",
    "packages/data-common",
    "packages/bb-app-setting",
    "packages/bb-data",
    "packages/bb-distributed-data",
    "packages/bb-auth-basic",
    "packages/bb-auth-cognito",
    "packages/bb-auth-oidc",
    "packages/bb-realtime",
    "packages/bb-async-job",
    "packages/bb-dashboard",
    "packages/bb-cron-job",
    "packages/bb-file-bucket",
    "packages/bb-agent",
    "packages/bb-knowledge-base",
    "packages/bb-logger",
    "packages/bb-email-client",
    "packages/bb-tracer",
    "packages/bb-metrics",
    "packages/blocks",
    "packages/create-blocks-app",
    "test-apps/comprehensive",
    "test-apps/comprehensive/aws-blocks",
    "test-apps/native-bindings",
    "test-apps/hosting-spa",
    "test-apps/hosting-ssr",
    "test-apps/hosting-ssr-nuxt",
    "test-apps/hosting-ssr-astro",
    "test-apps/hosting-ssr-astro-default404",
    "test-apps/hosting-spa/aws-blocks",
    "test-apps/hosting-ssr/aws-blocks",
    "test-apps/hosting-ssr-nuxt/aws-blocks",
    "test-apps/hosting-ssr-astro/aws-blocks",
    "test-apps/hosting-ssr-astro-default404/aws-blocks",
    "test-apps/vpc-smoke",
    "test-apps/extending-blocks-guide",
    "test-apps/extending-blocks-guide/aws-blocks",
    "test-apps/extending-blocks-guide/packages/bb-queue",
    "test-apps/extending-blocks-guide-blocksbackend",
    "test-apps/extending-blocks-guide-blocksbackend/aws-blocks",
    "test-apps/amplify-gen2",
    "test-apps/amplify-gen2/aws-blocks",
    "test-apps/auth-cognito-passkeys",
    "test-apps/auth-cognito-passkeys/aws-blocks",
    "test-apps/pipeline",
    "test-apps/db-pull-typecheck"
  ],
  "scripts": {
    "prepare": "husky && bash scripts/setup-git-secrets.sh",
    "clean": "rm -rf packages/*/dist packages/*/*.tsbuildinfo test-apps/*/dist test-apps/*/.next test-apps/*/*.tsbuildinfo",
    "build": "npm run build --workspaces --if-present",
    "build:packages": "npm run build --if-present -w packages/hosting -w packages/pipeline -w packages/core -w packages/bb-kv-store -w packages/bb-distributed-table -w packages/auth-common -w packages/data-common -w packages/bb-data -w packages/bb-distributed-data -w packages/bb-app-setting -w packages/bb-auth-basic -w packages/bb-auth-cognito -w packages/bb-auth-oidc -w packages/bb-realtime -w packages/bb-async-job -w packages/bb-cron-job -w packages/bb-file-bucket -w packages/bb-agent -w packages/bb-knowledge-base -w packages/bb-logger -w packages/bb-email-client -w packages/bb-tracer -w packages/bb-metrics -w packages/bb-dashboard -w packages/blocks -w packages/create-blocks-app",
    "build:force": "npm run clean && npm run build",
    "dev": "tsc --build --watch",
    "nuke": "rm -rf node_modules packages/*/node_modules test-apps/*/node_modules packages/*/dist test-apps/*/dist test-apps/*/.next packages/*/*.tsbuildinfo test-apps/*/*.tsbuildinfo",
    "test": "npm run test --workspaces",
    "test:unit": "npm run test --workspaces",
    "test:e2e:local": "cd test-apps/comprehensive && npm run test:e2e:local && cd ../.. && npm run test:vendorize",
    "test:e2e:sandbox": "cd test-apps/comprehensive && npm run test:e2e:sandbox",
    "test:e2e:production": "cd test-apps/comprehensive && npm run test:e2e:production",
    "test:e2e:local:vpc": "cd test-apps/vpc-smoke && npm run test:e2e:local",
    "test:e2e:sandbox:vpc": "cd test-apps/vpc-smoke && npm run test:e2e:sandbox",
    "test:e2e:production:vpc": "cd test-apps/vpc-smoke && npm run test:e2e:production",
    "test:all": "npm run test:unit && npm run test:e2e:local && npm run test:e2e:sandbox && npm run test:e2e:production",
    "test:dev": "npm run test:unit && npm run test:e2e:local && npm run test:e2e:sandbox",
    "test:templates": "bash scripts/test-templates-e2e.sh",
    "test:vendorize": "cd test-apps/comprehensive && npx tsx --test test/vendorize.test.ts",
    "create-app": "node packages/create-blocks-app/dist/index.js",
    "create-demo": "node packages/create-blocks-app/dist/index.js --template demo",
    "update-template": "tsx scripts/update-template-from-demo.ts",
    "build:tech-design-pdf": "node scripts/build-tech-design-pdf.mjs",
    "review-pr": "bash scripts/review-pr.sh",
    "publish:dry-run": "tsx scripts/publish/publish.ts",
    "publish:npm": "tsx scripts/publish/publish-npm.ts",
    "publish:s3": "tsx scripts/publish/publish.ts",
    "monte-carlo": "tsx scripts/monte-carlo.ts",
    "monte-carlo:cached": "tsx scripts/monte-carlo.ts --cached",
    "canary": "tsx scripts/canary/run-canary.ts",
    "test:e2e:supabase": "node --test packages/bb-data/dist/crud/crud-e2e.test.js packages/bb-data/dist/crud/migrations-e2e.test.js",
    "test:e2e:hosting-spa": "cd test-apps/hosting-spa && npm run test:e2e:sandbox",
    "test:e2e:hosting-ssr": "cd test-apps/hosting-ssr && npm run test:e2e:sandbox",
    "test:e2e:hosting-ssr-nuxt": "cd test-apps/hosting-ssr-nuxt && npm run test:e2e:sandbox",
    "test:e2e:hosting-ssr-astro": "cd test-apps/hosting-ssr-astro && npm run test:e2e:sandbox",
    "test:e2e:hosting-ssr-astro-default404": "cd test-apps/hosting-ssr-astro-default404 && npm run test:e2e:sandbox",
    "check:exports-consistency": "npx tsx scripts/check-aws-blocks-exports-consistency.ts",
    "lint": "biome lint --skip=correctness/noUndeclaredDependencies --reporter=github --changed --since=origin/main packages/",
    "lint:deps": "npx tsx scripts/lint-deps.ts",
    "update:api": "bash scripts/update-api-reports.sh",
    "check:api": "bash scripts/update-api-reports.sh && npx tsx scripts/check-api-reports.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@mermaid-js/mermaid-cli": "^11.12.0",
    "@microsoft/api-extractor": "^7.58.1",
    "@types/node": "^20.0.0",
    "aws-cdk": "^2.1117.0",
    "aws-cdk-lib": "2.257.0",
    "constructs": "^10.6.0",
    "esbuild": "^0.27.1",
    "husky": "^9.1.7",
    "kysely": "^0.28.17",
    "marked": "^18.0.0",
    "marked-highlight": "^2.2.3",
    "md-to-pdf": "^5.2.5",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "yaml": "^2.4.2",
    "jiti": "^2.7.0"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "^4.60.3"
  }
}
