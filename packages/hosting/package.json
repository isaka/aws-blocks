{
  "name": "@aws-blocks/hosting",
  "version": "0.1.3",
  "author": "Amazon Web Services",
  "license": "Apache-2.0",
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "src",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./constructs": {
      "types": "./dist/constructs/hosting_construct.d.ts",
      "default": "./dist/constructs/hosting_construct.js"
    },
    "./adapters": {
      "types": "./dist/adapters/index.d.ts",
      "default": "./dist/adapters/index.js"
    },
    "./error": {
      "types": "./dist/hosting_error.d.ts",
      "default": "./dist/hosting_error.js"
    }
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc --build && npm run bundle:handlers",
    "bundle:handlers": "node scripts/bundle-handlers.mjs",
    "test": "node --test dist/**/*.test.js",
    "dev": "tsc --build --watch"
  },
  "dependencies": {
    "@aws-sdk/client-cloudfront-keyvaluestore": "^3.1075.0",
    "@aws-sdk/signature-v4a": "^3.1069.0",
    "cross-spawn": "^7.0.6",
    "fast-glob": "^3.3.2",
    "jiti": "^2.4.0",
    "local-pkg": "^0.5.0",
    "parse-cache-control": "^1.0.1",
    "semver": "^7.6.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/cross-spawn": "^6.0.6",
    "@types/node": "^20.0.0",
    "@types/parse-cache-control": "^1.0.4",
    "@types/semver": "^7.5.8",
    "esbuild": "^0.27.0",
    "typescript": "^5.3.0"
  },
  "peerDependencies": {
    "@opennextjs/aws": ">=3.10.0",
    "aws-cdk-lib": "^2.257.0",
    "constructs": "^10.6.0"
  },
  "peerDependenciesMeta": {
    "@opennextjs/aws": {
      "optional": true
    }
  }
}
